# Frontend - React + Vite
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy frontend code
COPY frontend/ .

# Build for production
RUN npm run build

# Serve with a lightweight HTTP server
FROM node:20-alpine
RUN npm install -g serve
WORKDIR /app

COPY --from=0 /app/dist ./dist

EXPOSE 5173

CMD ["serve", "-s", "dist", "-l", "5173"]
